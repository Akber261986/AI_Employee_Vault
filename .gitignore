# ============================================
# Bronze Tier AI Employee - Hackathon Submission
# .gitignore - Only push essential project files
# ============================================

# ============================================
# Runtime Data (Don't Push)
# ============================================

# Logs - Generated at runtime
Logs/*.log
Logs/events_*.log
Logs/watcher.log

# User Data - Runtime generated tasks and files
Done/*.md
Inbox/*
!Inbox/.gitkeep
Needs_Action/*.md
!Needs_Action/.gitkeep

# Keep sample task for demonstration
!Needs_Action/SAMPLE_*.md

# Approval folders - Runtime data
Pending_Approval/*.md
Approved/*.md
Rejected/*.md

# Plans - Runtime generated
Plans/*.md

# Keep .gitkeep files to preserve folder structure
!*/.gitkeep

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
env/
venv/
.venv
ENV/
env.bak/
venv.bak/

# ============================================
# Obsidian
# ============================================
.obsidian/workspace*
.obsidian/cache
.obsidian/plugins/
.obsidian/themes/

# ============================================
# Operating System
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ============================================
# IDEs and Editors
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ============================================
# Temporary Files
# ============================================
*.tmp
*.temp
*.bak
*.backup
~*

# ============================================
# Security & Credentials (Silver Tier+)
# ============================================
.env
.env.local
.env.*.local
credentials/
tokens/
sessions/
*.key
*.pem
secrets/
*.pickle

# ============================================
# Node.js (if MCP servers added later)
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ============================================
# Testing
# ============================================
.pytest_cache/
.coverage
htmlcov/
*.cover
